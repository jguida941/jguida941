    "contracts_layout": {
      "root": "contracts",
      "glob": "**/*.json",
      "placement_enforced": true,
      "root_allowlist": ["repo_layout.json", "page_manifest.json"],
      "group_dirs": ["design_profiles"]
    },
    "site_layout": {
      "purpose": "P5-0-FINISH: closed cover over GENERATED site HTML so an undeclared site/*.html is structurally unconstructable (the precondition for the design-system showcase/settings homes). site/data/* is hydrated JSON, never matched by the *.html glob. Bespoke root_allowlist + group_dirs method (like contracts_layout); site/ is a root+allowlist shape, NOT a groups/target_dir shape, so it is deliberately NOT in the _ENUMERATED loop (codex R7). showcase.html / settings.html join root_allowlist, and a showcase/ subdir joins group_dirs, only in the slice that creates them.",
      "root": "site",
      "glob": "**/*.html",
      "root_allowlist": ["index.html", "settings.html", "showcase.html", "studio.html"],
      "group_dirs": []
    },
    "receipts_layout": {
      "purpose": "1b (codex must-fix #1) + D-SHELL MF1: closed cover over design-system conformance and page receipts so `assets/` is no longer ungoverned. Profile receipts live under `assets/receipts/<lang>/` where `<lang>` is a KNOWN design profile (active OR reserved) — the allowlist is `design_profiles/_index.json` (single source, read by the guard, NOT hardcoded here). Page layout receipts live under `assets/receipts/pages/<page>/`, where page is declared here. A receipt for an unknown profile or page reddens, so producers can't drop artifacts into an ungoverned tree. Only `assets/receipts/` is gated (the bot-regenerated `assets/*.svg` cards are a separate concern).",
      "root": "assets/receipts",
      "globs": ["**/*.json", "**/*.png"],
      "page_dir": "pages",
      "page_allowlist": ["index", "settings", "showcase", "studio"]
    }
  }
