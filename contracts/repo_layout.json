      "globs": ["**/*.json", "**/*.json.gz", "**/*.html.gz", "**/*.png"],
      "page_dir": "pages",
      "page_allowlist": ["index", "settings", "showcase", "studio"],
      "reference_pack_dir": "reference-packs",
